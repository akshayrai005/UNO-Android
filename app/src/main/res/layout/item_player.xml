<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="78dp"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="7dp"
    android:background="@drawable/bg_player_item"
    android:layout_marginEnd="8dp">

    <!-- Active turn glow bar at top -->
    <View
        android:id="@+id/vActiveIndicator"
        android:layout_width="30dp"
        android:layout_height="3dp"
        android:background="#FFD700"
        android:visibility="invisible"
        android:layout_marginBottom="5dp" />

    <!-- Avatar with initial letter -->
    <FrameLayout
        android:layout_width="36dp"
        android:layout_height="36dp">

        <View
            android:id="@+id/vAvatar"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/circle_shape" />

        <TextView
            android:id="@+id/tvAvatarInitial"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold" />
    </FrameLayout>

    <!-- Player name -->
    <TextView
        android:id="@+id/tvPlayerName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="@color/white_90"
        android:textSize="@dimen/text_xs"
        android:textStyle="bold"
        android:gravity="center"
        android:maxLines="1"
        android:ellipsize="end"
        android:layout_marginTop="4dp" />

    <!-- Card count -->
    <TextView
        android:id="@+id/tvCardCount"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/white_70"
        android:textSize="@dimen/text_xs"
        android:gravity="center"
        android:layout_marginTop="2dp" />

    <!-- UNO badge -->
    <TextView
        android:id="@+id/tvUnoAlert"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="UNO!"
        android:textColor="#FF1744"
        android:textStyle="bold"
        android:textSize="@dimen/text_xs"
        android:background="#30FF1744"
        android:paddingHorizontal="6dp"
        android:paddingVertical="1dp"
        android:visibility="gone"
        android:layout_marginTop="2dp" />

</LinearLayout>
