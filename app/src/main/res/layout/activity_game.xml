<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_game_table"
    android:keepScreenOn="true"
    android:fitsSystemWindows="true">

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!--  TOP RAIL — Other players                                          -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvPlayers"
        android:layout_width="0dp"
        android:layout_height="@dimen/player_panel_height"
        android:orientation="horizontal"
        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="8dp"
        android:paddingHorizontal="12dp"
        android:clipToPadding="false" />

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!--  TURN INDICATOR BAR                                                -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <TextView
        android:id="@+id/tvTurnIndicator"
        android:layout_width="0dp"
        android:layout_height="@dimen/turn_indicator_height"
        android:text="@string/your_turn"
        android:textSize="@dimen/text_lg"
        android:textStyle="bold"
        android:textColor="@color/turn_gold"
        android:gravity="center"
        android:background="@drawable/bg_turn_indicator"
        app:layout_constraintTop_toBottomOf="@id/rvPlayers"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="6dp" />

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!--  CENTER TABLE                                                      -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layoutCenter"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/tvTurnIndicator"
        app:layout_constraintBottom_toTopOf="@id/layoutInfo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:id="@+id/btnDrawPile"
            android:layout_width="@dimen/pile_width"
            android:layout_height="@dimen/pile_height"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/bg_draw_pile"
            android:clickable="true"
            android:focusable="true"
            android:elevation="4dp"
            app:layout_constraintEnd_toStartOf="@id/dividerCenter"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            android:layout_marginEnd="10dp">

            <View
                android:layout_width="62dp"
                android:layout_height="88dp"
                android:background="@drawable/bg_draw_pile"
                android:rotation="-4"
                android:translationX="-2dp"
                android:translationY="3dp"
                android:elevation="1dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="DRAW"
                android:textColor="@color/white_70"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.15"
                android:layout_marginTop="-70dp" />

            <TextView
                android:id="@+id/tvDeckCountPile"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="52"
                android:textColor="@color/white_50"
                android:textSize="10sp"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <View
            android:id="@+id/dividerCenter"
            android:layout_width="20dp"
            android:layout_height="1dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

        <FrameLayout
            android:id="@+id/layoutDiscard"
            android:layout_width="@dimen/pile_width"
            android:layout_height="@dimen/pile_height"
            android:elevation="4dp"
            app:layout_constraintStart_toEndOf="@id/dividerCenter"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            android:layout_marginStart="10dp">

            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_discard_area" />

            <com.uno.game.ui.game.UnoCardView
                android:id="@+id/cardTop"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:visibility="invisible" />
        </FrameLayout>

        <LinearLayout
            android:id="@+id/layoutColorInfo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            android:layout_marginEnd="12dp">

            <View
                android:id="@+id/tvCurrentColor"
                android:layout_width="@dimen/color_indicator_size"
                android:layout_height="@dimen/color_indicator_size"
                android:background="@drawable/circle_shape" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/current_color"
                android:textColor="@color/white_50"
                android:textSize="8sp"
                android:gravity="center"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvDirection"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="↻"
            android:textColor="@color/white_70"
            android:textSize="22sp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            android:layout_marginStart="14dp" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!--  INFO ROW                                                          -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/layoutInfo"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingVertical="4dp"
        app:layout_constraintBottom_toTopOf="@id/rvHand"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/tvDeckCountText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="@color/white_50"
            android:textSize="@dimen/text_sm"
            android:text="@string/loading" />

        <TextView
            android:id="@+id/tvPendingDraw"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/danger_red"
            android:textStyle="bold"
            android:textSize="@dimen/text_sm"
            android:visibility="gone" />
    </LinearLayout>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!--  MY HAND                                                           -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvHand"
        android:layout_width="0dp"
        android:layout_height="@dimen/hand_height"
        android:background="@drawable/bg_card_hand"
        app:layout_constraintBottom_toTopOf="@id/layoutActionBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:paddingHorizontal="8dp"
        android:paddingVertical="4dp"
        android:clipToPadding="false" />

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!--  BOTTOM ACTION BAR — paddingBottom pushes above nav bar           -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/layoutActionBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingTop="10dp"
        android:paddingHorizontal="10dp"
        android:paddingBottom="20dp"
        android:gravity="center_vertical"
        android:background="@drawable/bg_bottom_action_bar"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <Button
            android:id="@+id/btnDraw"
            android:layout_width="0dp"
            android:layout_height="46dp"
            android:layout_weight="2.2"
            android:text="@string/draw_card"
            android:textSize="13sp"
            android:textStyle="bold"
            android:backgroundTint="@color/uno_blue"
            android:layout_marginEnd="6dp"
            style="@style/Button.UNO.Action" />

        <Button
            android:id="@+id/btnUno"
            android:layout_width="0dp"
            android:layout_height="46dp"
            android:layout_weight="1.4"
            android:text="@string/uno"
            android:textStyle="bold"
            android:backgroundTint="@color/uno_red"
            android:textSize="16sp"
            android:visibility="gone"
            android:layout_marginEnd="6dp"
            style="@style/Button.UNO.Action" />

        <ImageButton
            android:id="@+id/btnMuteSound"
            android:layout_width="46dp"
            android:layout_height="46dp"
            android:src="@drawable/ic_sound_on"
            android:backgroundTint="@color/bg_surface_elevated"
            android:contentDescription="Toggle sound"
            android:padding="10dp" />

        <ImageButton
            android:id="@+id/btnMuteMic"
            android:layout_width="46dp"
            android:layout_height="46dp"
            android:src="@drawable/ic_mic_on"
            android:backgroundTint="@color/bg_surface_elevated"
            android:contentDescription="Toggle microphone"
            android:padding="10dp"
            android:layout_marginStart="6dp" />

    </LinearLayout>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!--  SPECTATOR OVERLAY                                                 -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/layoutSpectator"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:background="#CC0A0A2A"
        android:paddingTop="14dp"
        android:paddingHorizontal="20dp"
        android:paddingBottom="28dp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/tvSpectatorTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="👀 SPECTATING"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#FFD700"
            android:gravity="center" />

        <TextView
            android:id="@+id/tvSpectatorSub"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Waiting for game to finish..."
            android:textSize="13sp"
            android:textColor="#AAFFFFFF"
            android:gravity="center"
            android:layout_marginTop="4dp" />

    </LinearLayout>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!--  GAME EVENT TOAST OVERLAY                                         -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <TextView
        android:id="@+id/tvEventToast"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text=""
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:background="#CC000000"
        android:paddingHorizontal="24dp"
        android:paddingVertical="12dp"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:elevation="10dp" />

</androidx.constraintlayout.widget.ConstraintLayout>
