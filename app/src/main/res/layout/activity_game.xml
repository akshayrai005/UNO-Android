<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1A0033"
    android:keepScreenOn="true">

    <!-- TOP: Other players scrollable -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvPlayers"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="4dp"
        android:paddingHorizontal="8dp"
        android:clipToPadding="false" />

    <!-- Turn Indicator -->
    <TextView
        android:id="@+id/tvTurnIndicator"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="YOUR TURN!"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#FFD700"
        android:gravity="center"
        android:padding="6dp"
        android:background="#33FFD700"
        app:layout_constraintTop_toBottomOf="@id/rvPlayers"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="4dp" />

    <!-- CENTER TABLE -->
    <LinearLayout
        android:id="@+id/layoutCenter"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="horizontal"
        android:gravity="center"
        app:layout_constraintTop_toBottomOf="@id/tvTurnIndicator"
        app:layout_constraintBottom_toTopOf="@id/tvDeckCount"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Draw pile -->
        <LinearLayout
            android:id="@+id/btnDrawPile"
            android:layout_width="90dp"
            android:layout_height="130dp"
            android:orientation="vertical"
            android:gravity="center"
            android:background="#2E004F"
            android:layout_marginEnd="20dp"
            android:clickable="true"
            android:focusable="true">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🃏"
                android:textSize="30sp" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="DRAW"
                android:textColor="#AAFFFFFF"
                android:textSize="11sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Top discard card (custom drawn) -->
        <com.uno.game.ui.game.UnoCardView
            android:id="@+id/cardTop"
            android:layout_width="90dp"
            android:layout_height="130dp" />

    </LinearLayout>

    <!-- Current Color dot -->
    <View
        android:id="@+id/tvCurrentColor"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:background="@drawable/circle_shape"
        app:layout_constraintTop_toTopOf="@id/layoutCenter"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginEnd="12dp" />

    <!-- Direction + Deck count row -->
    <LinearLayout
        android:id="@+id/tvDeckCount"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        app:layout_constraintBottom_toTopOf="@id/rvHand"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="4dp">

        <TextView
            android:id="@+id/tvDeckCountText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="#AAFFFFFF"
            android:textSize="12sp"
            android:text="Deck: 0" />

        <TextView
            android:id="@+id/tvDirection"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#AAFFFFFF"
            android:textSize="12sp"
            android:text="→ Clockwise" />

    </LinearLayout>

    <!-- MY HAND -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvHand"
        android:layout_width="0dp"
        android:layout_height="130dp"
        app:layout_constraintBottom_toTopOf="@id/layoutButtons"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="6dp"
        android:paddingHorizontal="8dp"
        android:clipToPadding="false" />

    <!-- BOTTOM BUTTONS -->
    <LinearLayout
        android:id="@+id/layoutButtons"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="8dp"
        android:gravity="center"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <Button
            android:id="@+id/btnDraw"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_weight="2"
            android:text="Draw Card"
            android:textSize="13sp"
            android:backgroundTint="#1E88E5"
            android:layout_marginEnd="6dp" />

        <Button
            android:id="@+id/btnUno"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_weight="1.2"
            android:text="UNO!"
            android:textStyle="bold"
            android:backgroundTint="#FF5722"
            android:textSize="16sp"
            android:visibility="gone"
            android:layout_marginEnd="6dp" />

        <ImageButton
            android:id="@+id/btnMuteSound"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:src="@android:drawable/ic_lock_silent_mode_off"
            android:backgroundTint="#607D8B" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
