<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="24dp"
    android:background="@drawable/bg_form_card">

    <TextView
        android:id="@+id/tvWinnerEmoji"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🎉"
        android:textSize="48sp"
        android:layout_marginBottom="4dp" />

    <TextView
        android:id="@+id/tvWinnerTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="GAME OVER"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="@color/turn_gold"
        android:letterSpacing="0.12"
        android:layout_marginBottom="12dp" />

    <!-- Scrollable rankings so dialog doesn't cover the whole screen -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:maxHeight="220dp">

        <LinearLayout
            android:id="@+id/layoutRankings"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="4dp" />
    </ScrollView>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🎙️ Mic &amp; Speaker still available below"
        android:textSize="11sp"
        android:textColor="#88FFFFFF"
        android:gravity="center"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="12dp" />

    <Button
        android:id="@+id/btnBackToMenu"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="@string/back_to_menu"
        android:backgroundTint="@color/uno_red"
        android:textColor="@color/white"
        android:textStyle="bold"
        style="@style/Button.UNO" />

</LinearLayout>
