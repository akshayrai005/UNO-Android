<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="28dp"
    android:background="@drawable/bg_form_card">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🎉"
        android:textSize="64sp"
        android:layout_marginBottom="8dp" />

    <TextView
        android:id="@+id/tvWinnerTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="GAME OVER"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="@color/turn_gold"
        android:letterSpacing="0.12"
        android:layout_marginBottom="8dp" />

    <TextView
        android:id="@+id/tvWinnerName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Player WINS!"
        android:textSize="18sp"
        android:textColor="@color/white_90"
        android:gravity="center"
        android:layout_marginBottom="28dp" />

    <Button
        android:id="@+id/btnBackToMenu"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="@string/back_to_menu"
        android:backgroundTint="@color/uno_red"
        android:textColor="@color/white"
        android:textStyle="bold"
        android:layout_marginBottom="10dp"
        style="@style/Button.UNO" />

</LinearLayout>
