<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_home">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp"
            android:gravity="center_horizontal">

            <!-- ── UNO Logo area ── -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginTop="36dp"
                android:layout_marginBottom="4dp">

                <!-- UNO logo oval bg -->
                <FrameLayout
                    android:layout_width="120dp"
                    android:layout_height="80dp">

                    <View
                        android:layout_width="120dp"
                        android:layout_height="80dp"
                        android:background="#CC000000"
                        android:rotation="-5" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:text="UNO"
                        android:textSize="42sp"
                        android:textStyle="bold"
                        android:textColor="#E53935"
                        android:fontFamily="sans-serif-black"
                        android:gravity="center"
                        android:shadowColor="#FF6B6B"
                        android:shadowDx="2"
                        android:shadowDy="2"
                        android:shadowRadius="8" />
                </FrameLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Online Multiplayer"
                    android:textSize="13sp"
                    android:textColor="@color/text_secondary"
                    android:letterSpacing="0.1"
                    android:layout_marginTop="8dp" />
            </LinearLayout>

            <!-- ── Form card ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp"
                android:background="@drawable/bg_form_card"
                android:layout_marginTop="20dp">

                <!-- Username input -->
                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/username_hint"
                    style="@style/TextInput.UNO"
                    android:layout_marginBottom="16dp">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etUsername"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/white"
                        android:maxLength="20"
                        android:inputType="textPersonName" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Color picker label -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/pick_color_label"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:letterSpacing="0.08"
                    android:layout_marginBottom="10dp" />

                <!-- Color dots row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:layout_marginBottom="20dp">

                    <View android:id="@+id/color1"
                        android:layout_width="@dimen/color_dot_size"
                        android:layout_height="@dimen/color_dot_size"
                        android:layout_margin="8dp"
                        android:background="@drawable/circle_shape" />
                    <View android:id="@+id/color2"
                        android:layout_width="@dimen/color_dot_size"
                        android:layout_height="@dimen/color_dot_size"
                        android:layout_margin="8dp"
                        android:background="@drawable/circle_shape" />
                    <View android:id="@+id/color3"
                        android:layout_width="@dimen/color_dot_size"
                        android:layout_height="@dimen/color_dot_size"
                        android:layout_margin="8dp"
                        android:background="@drawable/circle_shape" />
                    <View android:id="@+id/color4"
                        android:layout_width="@dimen/color_dot_size"
                        android:layout_height="@dimen/color_dot_size"
                        android:layout_margin="8dp"
                        android:background="@drawable/circle_shape" />
                </LinearLayout>

                <!-- Create Room -->
                <Button
                    android:id="@+id/btnCreateRoom"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/button_height"
                    android:text="@string/create_room"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:backgroundTint="@color/uno_red"
                    android:layout_marginBottom="10dp"
                    style="@style/Button.UNO" />

                <!-- Divider -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/or_join"
                    android:textColor="@color/text_hint"
                    android:layout_gravity="center"
                    android:layout_marginBottom="10dp" />

                <!-- Room code input -->
                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/room_code_hint"
                    style="@style/TextInput.UNO"
                    android:layout_marginBottom="10dp">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etRoomCode"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/white"
                        android:maxLength="8"
                        android:inputType="textCapCharacters" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Join Room -->
                <Button
                    android:id="@+id/btnJoinRoom"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/button_height"
                    android:text="@string/join_room"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:backgroundTint="@color/uno_blue"
                    style="@style/Button.UNO" />
            </LinearLayout>

            <!-- Footer -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/made_by"
                android:textColor="@color/text_hint"
                android:textSize="11sp"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="16dp" />
        </LinearLayout>
    </ScrollView>

</FrameLayout>
