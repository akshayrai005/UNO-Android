<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1A0033">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center_horizontal">

        <!-- UNO Logo -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="UNO"
            android:textSize="72sp"
            android:textStyle="bold"
            android:textColor="#FFD700"
            android:fontFamily="sans-serif-black"
            android:layout_marginTop="48dp"
            android:shadowColor="#FF0000"
            android:shadowDx="4"
            android:shadowDy="4"
            android:shadowRadius="8" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Online Multiplayer"
            android:textSize="16sp"
            android:textColor="#CCFFFFFF"
            android:layout_marginBottom="40dp" />

        <!-- Username -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Your Username"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_marginBottom="16dp">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etUsername"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@android:color/white"
                android:maxLength="20"
                android:inputType="textPersonName" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Avatar Color Picker -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Pick Your Color"
            android:textColor="#CCFFFFFF"
            android:textSize="14sp"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="24dp">
            <View android:id="@+id/color1" android:layout_width="36dp" android:layout_height="36dp" android:layout_margin="4dp" android:background="@drawable/circle_shape" />
            <View android:id="@+id/color2" android:layout_width="36dp" android:layout_height="36dp" android:layout_margin="4dp" android:background="@drawable/circle_shape" />
            <View android:id="@+id/color3" android:layout_width="36dp" android:layout_height="36dp" android:layout_margin="4dp" android:background="@drawable/circle_shape" />
            <View android:id="@+id/color4" android:layout_width="36dp" android:layout_height="36dp" android:layout_margin="4dp" android:background="@drawable/circle_shape" />
            <View android:id="@+id/color5" android:layout_width="36dp" android:layout_height="36dp" android:layout_margin="4dp" android:background="@drawable/circle_shape" />
            <View android:id="@+id/color6" android:layout_width="36dp" android:layout_height="36dp" android:layout_margin="4dp" android:background="@drawable/circle_shape" />
            <View android:id="@+id/color7" android:layout_width="36dp" android:layout_height="36dp" android:layout_margin="4dp" android:background="@drawable/circle_shape" />
            <View android:id="@+id/color8" android:layout_width="36dp" android:layout_height="36dp" android:layout_margin="4dp" android:background="@drawable/circle_shape" />
        </LinearLayout>

        <!-- Create Room -->
        <Button
            android:id="@+id/btnCreateRoom"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="CREATE ROOM"
            android:textSize="18sp"
            android:textStyle="bold"
            android:backgroundTint="#E53935"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="— OR JOIN —"
            android:textColor="#AAFFFFFF"
            android:layout_marginBottom="16dp" />

        <!-- Join Room -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Enter Room Code"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_marginBottom="12dp">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etRoomCode"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@android:color/white"
                android:maxLength="8"
                android:inputType="textCapCharacters" />
        </com.google.android.material.textfield.TextInputLayout>

        <Button
            android:id="@+id/btnJoinRoom"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="JOIN ROOM"
            android:textSize="18sp"
            android:textStyle="bold"
            android:backgroundTint="#1E88E5"
            android:layout_marginBottom="32dp" />

    </LinearLayout>
</ScrollView>
