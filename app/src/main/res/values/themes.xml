<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.UNO" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/uno_red</item>
        <item name="colorPrimaryVariant">@color/uno_red_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/uno_blue</item>
        <item name="colorSecondaryVariant">@color/uno_blue_dark</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="android:windowBackground">@color/bg_dark</item>
        <item name="android:statusBarColor">@color/bg_darker</item>
        <item name="android:navigationBarColor">@color/bg_darker</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textColorHint">@color/text_hint</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:fontFamily">sans-serif</item>
    </style>

    <style name="Theme.UNO.Home" parent="Theme.UNO">
        <item name="android:windowBackground">@color/bg_home</item>
        <item name="android:statusBarColor">@color/bg_home</item>
        <item name="android:navigationBarColor">@color/bg_home</item>
    </style>

    <!-- Button Styles -->
    <style name="Button.UNO.Primary" parent="Widget.MaterialComponents.Button">
        <item name="android:textColor">@color/white</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">16sp</item>
        <item name="android:letterSpacing">0.08</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:minHeight">52dp</item>
        <item name="backgroundTint">@color/uno_red</item>
        <item name="rippleColor">@color/white_20</item>
    </style>

    <style name="Button.UNO.Secondary" parent="Widget.MaterialComponents.Button">
        <item name="android:textColor">@color/white</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">16sp</item>
        <item name="android:letterSpacing">0.08</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:minHeight">52dp</item>
        <item name="backgroundTint">@color/uno_blue</item>
        <item name="rippleColor">@color/white_20</item>
    </style>

    <style name="Button.UNO" parent="Widget.MaterialComponents.Button">
        <item name="android:textColor">@color/white</item>
        <item name="android:textStyle">bold</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:minHeight">52dp</item>
    </style>

    <!-- Card Action Bar Button style -->
    <style name="Button.UNO.Action" parent="Widget.MaterialComponents.Button">
        <item name="android:textColor">@color/white</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">14sp</item>
        <item name="cornerRadius">10dp</item>
        <item name="android:minHeight">46dp</item>
        <item name="backgroundTint">@color/uno_blue</item>
    </style>

    <!-- TextInputLayout style -->
    <style name="TextInput.UNO" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/input_stroke_selector</item>
        <item name="boxCornerRadiusBottomEnd">12dp</item>
        <item name="boxCornerRadiusBottomStart">12dp</item>
        <item name="boxCornerRadiusTopEnd">12dp</item>
        <item name="boxCornerRadiusTopStart">12dp</item>
        <item name="hintTextColor">@color/text_hint</item>
        <item name="android:textColorHint">@color/text_hint</item>
        <item name="boxBackgroundColor">@color/input_bg</item>
    </style>
</resources>
